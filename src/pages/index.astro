---
import BaseLayout from '../layouts/BaseLayout.astro';
import home from '../data/home.json';
---
<BaseLayout title="Keepsite Media — websites you own and keep">
  <main>
    <section class="section hero">
      <canvas id="hero-net" class="hero-net" aria-hidden="true"></canvas>
      <div class="container">
        <h1>{home.heroHeadline}</h1>
        <p class="hero-sub muted">{home.heroSub}</p>
        <p><a class="btn" href="/contact">Start a project</a>
        <a class="btn btn-outline" href="/pricing" style="margin-left:0.75rem">See pricing</a></p>
        <p class="hourly muted">{home.hourlyLine}</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>Why own it?</h2>
        <div class="grid grid-2">
          {home.valueProps.map((v) => (
            <div class="card">
              <h3>{v.title}</h3>
              <p class="muted">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="costs-panel">
          <h2>{home.runningCosts.heading}</h2>
          <p class="costs-intro muted">{home.runningCosts.intro}</p>
          <div class="grid grid-2 costs-grid">
            {home.runningCosts.points.map((p) => (
              <div class="cost-point">
                <h3>{p.label}</h3>
                <p class="muted">{p.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section center">
      <div class="container">
        <h2>{home.closingHeadline}</h2>
        <p><a class="btn" href="/contact">Get in touch</a></p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Hero holds an animated node-network canvas behind its content. */
  .hero { position: relative; overflow: hidden; }
  .hero-net {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    /* fade the network out toward the bottom so copy below breathes */
    -webkit-mask-image: linear-gradient(to bottom, #000 60%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 60%, transparent 100%);
  }
  .hero .container { position: relative; z-index: 1; }

  .hero-sub { max-width: 56ch; font-size: 1.15rem; }
  .hourly { max-width: 56ch; margin-top: var(--space-3); font-size: 0.95rem; }
  .hero h1 { max-width: 18ch; }

  /* "No ongoing costs" panel — sits on a solid surface so it reads
     clearly above the hero's network backdrop. */
  .costs-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
  }
  .costs-intro { max-width: 62ch; }
  .costs-grid { margin-top: var(--space-4); }
  .cost-point h3 { margin-bottom: var(--space-1); }
  .cost-point h3::before {
    content: "✓";
    color: var(--color-accent);
    font-weight: 800;
    margin-right: 0.5rem;
  }
</style>

<script>
  // Animated "connected node network" behind the hero. Pure canvas, no deps.
  // Decorative: skips entirely under reduced-motion, and pauses when the
  // hero is off-screen or the tab is hidden to stay light on the battery.
  const canvas = document.getElementById('hero-net') as HTMLCanvasElement | null;
  const host = canvas?.parentElement;

  if (canvas && host) {
    const ctx = canvas.getContext('2d');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    const LINK_DIST = 150;      // px: connect nodes closer than this
    const SPEED = 0.20;         // px/frame drift
    const ACCENT = '47, 125, 91'; // --color-accent as RGB

    let w = 0, h = 0, dpr = 1;
    let nodes: { x: number; y: number; vx: number; vy: number }[] = [];
    let raf = 0;
    let running = false;

    const rand = (n: number) => Math.random() * n;

    function build() {
      const rect = host!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = Math.round(w * dpr);
      canvas!.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      // density scales with area, capped so it never gets heavy
      const count = Math.max(14, Math.min(60, Math.round((w * h) / 16000)));
      nodes = Array.from({ length: count }, () => ({
        x: rand(w),
        y: rand(h),
        vx: (Math.random() - 0.5) * SPEED * 2,
        vy: (Math.random() - 0.5) * SPEED * 2,
      }));
    }

    function frame() {
      ctx!.clearRect(0, 0, w, h);

      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x <= 0 || n.x >= w) n.vx *= -1;
        if (n.y <= 0 || n.y >= h) n.vy *= -1;
      }

      // links
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const dist = Math.hypot(dx, dy);
          if (dist < LINK_DIST) {
            const a = (1 - dist / LINK_DIST) * 0.28;
            ctx!.strokeStyle = `rgba(${ACCENT}, ${a})`;
            ctx!.lineWidth = 1;
            ctx!.beginPath();
            ctx!.moveTo(nodes[i].x, nodes[i].y);
            ctx!.lineTo(nodes[j].x, nodes[j].y);
            ctx!.stroke();
          }
        }
      }

      // nodes
      ctx!.fillStyle = `rgba(${ACCENT}, 0.55)`;
      for (const n of nodes) {
        ctx!.beginPath();
        ctx!.arc(n.x, n.y, 1.8, 0, Math.PI * 2);
        ctx!.fill();
      }

      raf = requestAnimationFrame(frame);
    }

    function start() {
      if (running || reduce.matches) return;
      running = true;
      raf = requestAnimationFrame(frame);
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    function drawStatic() {
      // single frame for reduced-motion users — texture without movement
      ctx!.clearRect(0, 0, w, h);
      frame();
      stop();
    }

    // Pause when the hero scrolls out of view
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting && !reduce.matches) start();
        else stop();
      }
    });
    io.observe(host);

    // Pause on hidden tab
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else if (!reduce.matches) start();
    });

    let resizeTimer = 0;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        const wasRunning = running;
        stop();
        build();
        if (wasRunning && !reduce.matches) start();
        else if (reduce.matches) drawStatic();
      }, 150);
    });

    build();
    if (reduce.matches) drawStatic();
    else start();

    // If the user toggles the OS motion setting live
    reduce.addEventListener?.('change', () => {
      if (reduce.matches) {
        stop();
        drawStatic();
      } else {
        start();
      }
    });
  }
</script>
